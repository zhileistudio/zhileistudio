{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "Portfolio project item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "tagline": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "categoryLabel": { "type": "string" },
        "imageUrl": { "type": "string" },
        "client": { "type": "string" },
        "year": { "type": "string" },
        "tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "details": { "type": "object" }
      },
      "required": ["id", "title", "description"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Portfolio work cards"
    }
  }
}
